# Copy to .env and fill in. Never commit .env.

# --- Read gate (everyone needs this to view trips) ---
PASSCODE=changeme

# --- Admin login (unlocks create/edit/delete) ---
# Generate a hash:  docker compose run --rm --no-deps --entrypoint /usr/local/bin/api api -hashpw "your-password"
# (or:  cd api && go run . -hashpw "your-password")
ADMIN_PASSWORD_HASH=
# 32+ random chars; signs session cookies. Keep stable or logins reset on restart.
SESSION_SECRET=

# --- Seed (a demo trip is installed on first run if the data volume is empty) ---
SEED_FILE=/seed/demo.json

# --- Receipt OCR (optional) ---
# Any OpenAI-compatible *vision* model. DeepSeek's API is text-only and CANNOT
# read images — point this at a cheap vision model instead (e.g. Gemini Flash).
# Gemini example:
#   OCR_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
#   OCR_MODEL=gemini-2.5-flash
OCR_API_BASE=
OCR_API_KEY=
OCR_MODEL=

# --- TezTun tunnel (only for the bundled docker-compose deploy) ---
TEZTUN_TOKEN=
